<main class="details">
    <section id="details">
        <div id="details-wrapper">


            <p id="details-title">{{CurrentProperty.type}}</p>

            <div id="img-wrapper">
                <img src="{{CurrentProperty.image}}" alt="Property Image" />
            </div>


            <div id="info-wrapper">
                <table>
                    <tr>
                        <td>
                            <p>
                                Contact: <a id="details-contact">{{CurrentProperty.contact}}</a>
                            </p>
                        </td>
                        <td>
                            <p>
                                Location:
                                <span id="details-location">{{CurrentProperty.location}}</span>
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td>
                            <p>
                                Area:
                                <span id="details-area">{{CurrentProperty.area}} sq.m</span>
                            </p>
                        </td>
                        <td>
                            <p>
                                Price:
                                <span id="details-price">{{CurrentProperty.price}} EUR</span>
                            </p>
                        </td>
                    </tr>
                </table>

                <p>
                    Description:
                    <span id="details-description">
                        {{CurrentProperty.description}}
                    </span>
                </p>
            </div>


            <div id="action-buttons">


                {{#if isCreator}}
                <a href="/edit/{{CurrentProperty._id}}" id="edit-btn">Edit</a>
                <a href="/delete/{{CurrentProperty._id}}" id="delete-btn">Delete</a>
                {{/if}}

                {{#if user}}
                {{#unless isCreator}}


                {{#if hasRecommended}}
                <p id="already-liked">You already liked this property!</p>
                {{else}}
                <a href="/like/{{CurrentProperty._id}}" id="like-btn">Like</a>
                {{/if}}

                {{/unless}}
                {{/if}}

            </div>

        </div>
    </section>
</main>